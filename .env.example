# PropTrack Production Environment Variables
# Copy this file to .env and replace placeholders with your actual production credentials

# Domain
DOMAIN_URL=http://proptrack.betahobby.dpdns.org

# Database
POSTGRES_USER=proptrack_user
POSTGRES_PASSWORD=generate_a_strong_password_here
POSTGRES_DB=proptrack

# Auth
# Generate with: openssl rand -base64 32
JWT_SECRET=generate_a_strong_random_string_here
JWT_EXPIRES_IN=7d

# Storage (MinIO)
MINIO_ROOT_USER=proptrack_admin
MINIO_ROOT_PASSWORD=generate_another_strong_password_here
MINIO_BUCKET=proptrack

# Geocoding
NOMINATIM_PASSWORD=generate_a_nominatim_password_here
GEOCODE_MAX_ATTEMPTS=3
GEOCODE_RETRY_INTERVAL_SECONDS=60
