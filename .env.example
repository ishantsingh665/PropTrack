# PropTrack Environment Variables
# Copy this file to .env and replace placeholders with your actual production credentials

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/proptrack

# Auth
JWT_SECRET=generate_a_strong_random_string_here

# Storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# Geocoding
NOMINATIM_URL=http://localhost:8080
GEOCODE_MAX_ATTEMPTS=3
GEOCODE_RETRY_INTERVAL_SECONDS=60

# Server
PORT=3000
FRONTEND_URL=http://localhost:5173
