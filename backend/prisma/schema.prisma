generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

enum GfaUnit {
  SQFT
  SQM
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String
  name               String
  role               UserRole  @default(VIEWER)
  preferredGfaUnit   GfaUnit   @default(SQFT)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  auditLogs          AuditLog[]
  snapshots          Snapshot[]
}

model Company {
  id                 String    @id @default(uuid())
  name               String
  registrationNumber String?
  countryCode        String    @db.Char(2)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  snapshotsEnabled    Boolean  @default(true)   // controls if this company is included in snapshots
  indexListed         Boolean  @default(false)  // controls if company appears in index
  isin                String?  @unique
  status              CompanyStatus @default(active)
  reportPropertyCount Int?

  properties         PropertyCompany[]
  notes              CompanyNote[]
  snapshotCompanies   SnapshotCompany[]
  companySnapshots    CompanyMonthlySnapshot[] // existing relation
}

enum CompanyStatus {
  active
  inactive
}

model PropertyType {
  id        String   @id @default(uuid())
  name      String
  parentId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent    PropertyType?  @relation("TypeHierarchy", fields: [parentId], references: [id])
  children  PropertyType[] @relation("TypeHierarchy")
  properties Property[]
}

enum PropertyLevel {
  building
  unit
}

enum GeocodeStatus {
  pending
  success
  failed
  manual_override
}

model Property {
  id                String        @id @default(uuid())
  parentId          String?
  propertyLevel     PropertyLevel
  propertyTypeId    String
  name              String?
  addressLine1      String
  addressLatin      String?
  addressNormalized String
  city              String
  postalCode        String?
  countryCode       String        @db.Char(2)
  latitude          Float?
  longitude         Float?
  geocodeStatus     GeocodeStatus @default(pending)
  geocodeAttempts   Int           @default(0)
  gfaSqft           Float?
  gfaInputValue     Float?
  gfaInputUnit      String?       // sqft, sqm, etc.
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  parent            Property?         @relation("PropertyUnits", fields: [parentId], references: [id])
  units             Property[]        @relation("PropertyUnits")
  type              PropertyType      @relation(fields: [propertyTypeId], references: [id])
  companies         PropertyCompany[]
  changeLogs        PropertyChangeLog[]
  scrapeLogs        PropertyScrapeLog[]

  snapshotProperties SnapshotProperty[]

  // For duplicates (either as the first or second in the pair)
  duplicatePairs1   DuplicatePair[] @relation("Property1")
  duplicatePairs2   DuplicatePair[] @relation("Property2")

  @@index([geocodeStatus])               // post-import geocode queue population
  @@index([addressNormalized, city, countryCode]) // duplicate engine grouping
  @@index([deletedAt])                   // soft-delete filters everywhere
}

enum OwnershipStatus {
  active
  sold
  transferred
  reversed
}

model PropertyCompany {
  id           String          @id @default(uuid())
  propertyId   String
  companyId    String
  ownershipPct Float
  status       OwnershipStatus @default(active)
  validFrom    DateTime        @default(now())
  validTo      DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  property     Property        @relation(fields: [propertyId], references: [id])
  company      Company         @relation(fields: [companyId], references: [id])
  statusLogs   PropertyStatusLog[]
  transferLegs PropertyTransferLeg[]

  @@index([companyId, status, validTo])  // dashboard + snapshot queries
  @@index([propertyId])                  // property detail lookups
}

model PropertyStatusLog {
  id                String          @id @default(uuid())
  propertyCompanyId String
  oldStatus         OwnershipStatus
  newStatus         OwnershipStatus
  changedAt         DateTime        @default(now())
  reason            String?

  propertyCompany   PropertyCompany @relation(fields: [propertyCompanyId], references: [id])
}

enum TransferType {
  transfer
  swap
  reversal
}

model PropertyTransfer {
  id                String        @id @default(uuid())
  type              TransferType
  transferDate      DateTime      @default(now())
  reversedBy        String?       // ID of the reversal transfer event
  notes             String?
  createdAt         DateTime      @default(now())

  legs              PropertyTransferLeg[]
}

model PropertyTransferLeg {
  id                 String          @id @default(uuid())
  transferId         String
  propertyCompanyId  String          // The record that was closed or opened
  direction          String          // 'out' (closing) or 'in' (opening)
  
  transfer           PropertyTransfer @relation(fields: [transferId], references: [id])
  propertyCompany    PropertyCompany  @relation(fields: [propertyCompanyId], references: [id])
}

enum DuplicateStatus {
  pending
  duplicate
  not_duplicate
  merged
}

model DuplicatePair {
  id          String          @id @default(uuid())
  property1Id String
  property2Id String
  status      DuplicateStatus @default(pending)
  matchLevel  String          // building, unit, cross_level
  scope       String          // same_company, cross_company, no_shared_ownership
  score       Float?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  property1   Property        @relation("Property1", fields: [property1Id], references: [id])
  property2   Property        @relation("Property2", fields: [property2Id], references: [id])

  @@index([property1Id, property2Id])    // pair existence checks
  @@index([status])                      // frontend filters by status
}

model MergeLog {
  id          String   @id @default(uuid())
  keepId      String
  removeId    String
  mergedAt    DateTime @default(now())
  mergedBy    String
  details     Json?
}

model AuditLog {
  id         String   @id @default(uuid())
  changedAt  DateTime @default(now())
  tableName  String
  recordId   String
  userId     String?
  action     String   // INSERT, UPDATE, DELETE
  diff       Json?

  user       User?    @relation(fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([changedAt])
}

model PropertyChangeLog {
  id         String    @id @default(uuid())
  propertyId String
  userId     String
  entry      String
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  deleteReason String?

  property   Property  @relation(fields: [propertyId], references: [id])
}

enum ImportStatus {
  pending
  processing
  completed
  failed
}

model ImportJob {
  id         String       @id @default(uuid())
  userId     String
  status     ImportStatus @default(pending)
  filename   String
  rowCount   Int?
  errorLog   Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model PropertyScrapeLog {
  id         String   @id @default(uuid())
  propertyId String
  source     String
  externalId String?
  data       Json?
  scrapedAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id])
}

model GeocodeQueue {
  id         String   @id @default(uuid())
  propertyId String
  attempts   Int      @default(0)
  lastError  String?
  nextRunAt  DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([nextRunAt])                   // queue processor polling
}

model CompanyNote {
  id          String   @id @default(uuid())
  companyId   String
  userId      String
  title       String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  company     Company  @relation(fields: [companyId], references: [id])
  attachments CompanyNoteAttachment[]
}

model CompanyNoteAttachment {
  id          String   @id @default(uuid())
  noteId      String
  filename    String
  fileSize    Int
  mimeType    String
  storagePath String
  createdAt   DateTime @default(now())

  note        CompanyNote @relation(fields: [noteId], references: [id])
}

model CompanyMonthlySnapshot {
  id               String   @id @default(uuid())
  companyId        String
  month            String   // YYYY-MM
  propertyCount    Int
  totalGfaSqft     Float
  activeStakeCount Int
  data             Json?
  createdAt        DateTime @default(now())

  company          Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, month])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Parent snapshot record — one per snapshot event
model Snapshot {
  id              String   @id @default(uuid())
  snapshotNumber  Int      @unique @default(autoincrement()) // assigned sequentially e.g. 1, 2, 3
  name            String   @unique                           // e.g. "December 2024"
  year            Int                                        // e.g. 2024
  createdAt       DateTime @default(now())
  createdBy       String                                     // userId
  creator         User     @relation(fields: [createdBy], references: [id])

  companySnapshots  SnapshotCompany[]
  propertySnapshots SnapshotProperty[]

  @@index([year])
  @@index([snapshotNumber])
}

// One record per company included in the snapshot
model SnapshotCompany {
  id              String   @id @default(uuid())
  snapshotId      String
  snapshot        Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  companyId       String                          // reference to original Company.id
  company         Company  @relation(fields: [companyId], references: [id])

  // Snapshot-specific unique ID for this company in this snapshot
  snapshotCompanyUid  String @unique @default(uuid())

  // Delta overrides — only non-null fields override the live value at read time
  nameOverride          String?
  isinOverride          String?
  statusOverride        String?
  reportPropertyCountOverride Int?
  notesOverride         String?

  // Computed totals captured at snapshot time (denormalized for performance)
  totalPropertyCount    Int      @default(0)
  totalGfaSqft          Float    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  propertySnapshots SnapshotProperty[]

  @@unique([snapshotId, companyId])
  @@index([snapshotId])
  @@index([companyId])
}

// One record per property included in the snapshot
model SnapshotProperty {
  id              String   @id @default(uuid())
  snapshotId      String
  snapshot        Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  propertyId      String                          // reference to original Property.id
  property        Property @relation(fields: [propertyId], references: [id])
  snapshotCompanyId String                        // which company this property belongs to in the snapshot
  snapshotCompany SnapshotCompany @relation(fields: [snapshotCompanyId], references: [id])

  // Snapshot-specific unique ID for this property in this snapshot
  snapshotPropertyUid String @unique @default(uuid())

  // Delta overrides — only non-null fields override the live value at read time
  nameOverride          String?
  addressLine1Override  String?
  cityOverride          String?
  gfaSqftOverride       Float?
  propertyLevelOverride String?
  notesOverride         String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([snapshotId, propertyId])
  @@index([snapshotId])
  @@index([propertyId])
  @@index([snapshotCompanyId])
}
